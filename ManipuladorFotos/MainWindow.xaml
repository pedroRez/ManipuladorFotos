<Window x:Class="ManipuladorFotos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Manipulador de Fotos"
        Height="860"
        Width="1400"
        MinHeight="720"
        MinWidth="1100"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F5F7FA"
        WindowStartupLocation="CenterScreen"
        Icon="icon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F6F8B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#E07A5F" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DFE6" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,12"
                Background="#1F6F8B">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="Manipulador de Fotos"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Organize, filtre e prepare limpeza de mídia com segurança"
                               FontSize="14"
                               Foreground="#E8F1F5"
                               Margin="0,4,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10"
                Visibility="{Binding ShowGlobalFolderBar, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding CurrentFolder, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Escolher Pasta"
                        Command="{Binding BrowseFolderCommand}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Incluir subpastas"
                              IsChecked="{Binding IncludeSubfolders}" />
                    <Button Content="Escanear"
                            Command="{Binding ScanFilesCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding SelectedMainTabIndex}"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </Border>
                </ControlTemplate>
            </TabControl.Template>
            <TabItem Header="Organizar Fotos">
                <Grid Margin="8">
                    <Grid Visibility="{Binding IsWorkflowWizardVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="16"
                                HorizontalAlignment="Center"
                                MaxWidth="1180">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="True">
                                    <Button Content="← Voltar"
                                            Command="{Binding WorkflowPreviousStepCommand}"
                                            Visibility="{Binding IsWorkflowPreviousVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                            DockPanel.Dock="Left"
                                            Margin="0,0,12,0" />
                                    <StackPanel DockPanel.Dock="Left">
                                        <TextBlock Text="Assistente de Organização"
                                                   FontSize="24"
                                                   FontWeight="Bold"
                                                   Foreground="#2E3A46" />
                                        <TextBlock Text="{Binding WorkflowStepTitle}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Margin="0,6,0,0"
                                                   Foreground="#1F6F8B" />
                                        <TextBlock Text="{Binding WorkflowStepHint}"
                                                   Margin="0,4,0,0"
                                                   Foreground="#55606B" />
                                    </StackPanel>
                                </DockPanel>

                                <WrapPanel Grid.Row="1" Margin="0,12,0,12">
                                    <TextBlock Text="1. Objetivo" FontWeight="SemiBold" Margin="0,0,14,0" />
                                    <TextBlock Text="2. Pasta e Scan" FontWeight="SemiBold" Margin="0,0,14,0" />
                                    <TextBlock Text="3. Opções" FontWeight="SemiBold" Margin="0,0,14,0" />
                                    <TextBlock Text="4. Execução" FontWeight="SemiBold" Margin="0,0,14,0" />
                                    <TextBlock Text="5. Resultado" FontWeight="SemiBold" />
                                </WrapPanel>

                                <Grid Grid.Row="2">
                                    <Border Visibility="{Binding IsWorkflowStep1, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Selecione o que você quer fazer:"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <ComboBox Width="560"
                                                      FontSize="16"
                                                      Padding="8,6"
                                                      ItemsSource="{Binding WorkflowObjectives}"
                                                      SelectedItem="{Binding WorkflowObjective}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Visibility="{Binding IsWorkflowStep2, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Selecione a pasta que será analisada:"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <DockPanel LastChildFill="True">
                                                <Button Content="Buscar Pasta"
                                                        Command="{Binding BrowseFolderCommand}"
                                                        DockPanel.Dock="Right" />
                                                <TextBox Text="{Binding CurrentFolder, UpdateSourceTrigger=PropertyChanged}" />
                                            </DockPanel>
                                            <CheckBox Content="Incluir subpastas"
                                                      IsChecked="{Binding IncludeSubfolders}"
                                                      Margin="0,6,0,0" />
                                            <TextBlock Text="Ao clicar em Próximo, o sistema fará o scanner automático."
                                                       Foreground="#55606B"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Visibility="{Binding IsWorkflowStep3, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <Grid>
                                                <Border Visibility="{Binding IsWorkflowObjectiveCleanup, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="Opções da limpeza de fotos"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,6" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Modo de limpeza:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0" />
                                                            <ComboBox Width="180"
                                                                      ItemsSource="{Binding CleanupModes}"
                                                                      SelectedItem="{Binding CleanupMode}" />
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Preferência para manter original:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0" />
                                                            <ComboBox Width="200"
                                                                      ItemsSource="{Binding KeepPreferenceOptions}"
                                                                      SelectedItem="{Binding KeepPreference}" />
                                                        </StackPanel>
                                                        <CheckBox Content="Comparar por nome igual"
                                                                  IsChecked="{Binding UseSameNameRule}" />
                                                        <CheckBox Content="Comparar por tamanho igual"
                                                                  IsChecked="{Binding UseSameSizeRule}" />
                                                        <CheckBox Content="Comparar por sequência parecida"
                                                                  IsChecked="{Binding UseSimilarInSequenceRule}" />
                                                    </StackPanel>
                                                </Border>

                                            <Border Visibility="{Binding IsWorkflowObjectiveUnwanted, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <StackPanel>
                                                    <TextBlock Text="Opções para arquivos indesejados"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,6" />
                                                    <TextBlock Text="Extensões (separadas por vírgula):" />
                                                    <TextBox Width="460"
                                                             Text="{Binding UnwantedExtensions, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Text="Sugestão para pastas de fotos/vídeos: .aae, .thm, .xmp, .lrv, .sfk, .pkf, .dop"
                                                               Margin="0,4,0,0"
                                                               Foreground="#55606B"
                                                               FontSize="11" />
                                                    <TextBlock Text="A seleção por extensão já define quais arquivos entram na limpeza."
                                                               Margin="0,8,0,0"
                                                               Foreground="#55606B" />
                                                </StackPanel>
                                            </Border>

                                                <Border Visibility="{Binding IsWorkflowObjectiveOrganize, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <StackPanel>
                                                        <TextBlock Text="Opções de organização"
                                                                   FontWeight="SemiBold"
                                                                   Margin="0,0,0,6" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Ação:"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,0,6,0" />
                                                            <ComboBox Width="260"
                                                                      ItemsSource="{Binding WorkflowOrganizeActions}"
                                                                      SelectedItem="{Binding WorkflowOrganizeAction}" />
                                                        </StackPanel>

                                                        <StackPanel Visibility="{Binding IsWorkflowOrganizeActionMedia, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal"
                                                                        Visibility="{Binding WorkflowOrganizeNeedsFolderName, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="Nome da pasta destino/base:"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" />
                                                                <TextBox Width="220"
                                                                         Text="{Binding MediaOperationFolderName, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Visibility="{Binding IsWorkflowOrganizeActionDate, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Organizar por:"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" />
                                                                <ComboBox Width="140"
                                                                          ItemsSource="{Binding DateOrganizationModes}"
                                                                          SelectedItem="{Binding DateOrganizationMode}" />
                                                            </StackPanel>
                                                            <CheckBox Content="Consolidar subpastas em base única"
                                                                      IsChecked="{Binding FlattenSubfoldersByDate}" />
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Pasta base:"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" />
                                                                <TextBox Width="220"
                                                                         Text="{Binding DateOrganizationBaseFolder, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                        </StackPanel>

                                                        <StackPanel Visibility="{Binding IsWorkflowOrganizeActionMove, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="Destino das fotos marcadas:"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" />
                                                                <TextBox Width="260"
                                                                         Text="{Binding NewMoveFolderPath, UpdateSourceTrigger=PropertyChanged}" />
                                                            </StackPanel>
                                                            <WrapPanel Margin="0,4,0,0">
                                                                <Button Content="Marcar Todos"
                                                                        Command="{Binding MarkAllDisplayedItemsCommand}" />
                                                                <Button Content="Desmarcar Todos"
                                                                        Command="{Binding UnmarkAllDisplayedItemsCommand}"
                                                                        Background="{StaticResource AccentBrush}" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="8"
                                                    Margin="0,12,0,0"
                                                    Visibility="{Binding WorkflowCanVisualizeFoundItems, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <TextBlock Text="{Binding WorkflowScanSummary}"
                                                           TextWrapping="Wrap"
                                                           FontWeight="SemiBold"
                                                           Foreground="#2E3A46" />
                                            </Border>
                                            <Button Content="Visualizar Arquivos Encontrados"
                                                    Command="{Binding WorkflowOpenFoundItemsCommand}"
                                                    Visibility="{Binding WorkflowCanVisualizeFoundItems, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    Margin="0,10,0,0"
                                                    HorizontalAlignment="Left" />
                                        </StackPanel>
                                    </Border>

                                    <Border Visibility="{Binding IsWorkflowStep4, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Tudo pronto para executar."
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Text="{Binding WorkflowStepHint}"
                                                       Foreground="#55606B"
                                                       Margin="0,0,0,10" />
                                            <Button Content="{Binding WorkflowExecuteLabel}"
                                                    Command="{Binding WorkflowExecuteStepCommand}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Visibility="{Binding IsWorkflowStep5, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Processo finalizado"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <Border Background="#F8FAFC"
                                                    BorderBrush="{StaticResource BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="8">
                                                <TextBlock Text="{Binding WorkflowExecutionSummary}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#2E3A46" />
                                            </Border>
                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Content="Nova operação"
                                                        Command="{Binding WorkflowRestartCommand}" />
                                                <Button Content="Revisar indesejados"
                                                        Command="{Binding WorkflowOpenUnwantedTabCommand}"
                                                        Visibility="{Binding CanOpenUnwantedFromWorkflow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Content="Iniciar revisão focada"
                                                        Command="{Binding StartFocusedReviewCommand}"
                                                        Visibility="{Binding CanStartFocusedReviewFromWorkflow, Converter={StaticResource BoolToVisibilityConverter}}" />
                                                <Button Content="Desfazer Última"
                                                        Command="{Binding UndoLastOperationCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <DockPanel Grid.Row="3" Margin="0,14,0,0">
                                    <Button Content="Avançar →"
                                            Command="{Binding WorkflowNextStepCommand}"
                                            Visibility="{Binding IsWorkflowNextVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                                            DockPanel.Dock="Right" />
                                </DockPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Visibility="{Binding IsWorkflowFocusedVisualization, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <DockPanel>
                                    <Button Content="← Voltar"
                                            Command="{Binding WorkflowCloseFoundItemsCommand}"
                                            DockPanel.Dock="Left"
                                            Margin="0,0,10,0" />
                                    <TextBlock Text="Visualização concentrada dos arquivos encontrados"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"
                                               Foreground="#2E3A46"
                                               DockPanel.Dock="Left" />
                                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                                        <Button Content="Marcar Todos"
                                                Command="{Binding MarkAllDisplayedItemsCommand}" />
                                        <Button Content="Desmarcar Todos"
                                                Command="{Binding UnmarkAllDisplayedItemsCommand}"
                                                Background="{StaticResource AccentBrush}" />
                                        <Button Content="{Binding WorkflowFoundItemsNextLabel}"
                                                Command="{Binding WorkflowFoundItemsNextStepCommand}"
                                                Visibility="{Binding IsWorkflowFoundItemsNextVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Text="{Binding WorkflowScanSummary}"
                                           Margin="0,6,0,0"
                                           Foreground="#55606B"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.9*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource CardBrush}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="8">
                                <DataGrid ItemsSource="{Binding DisplayedItems}"
                                          SelectedItem="{Binding SelectedItem}"
                                          IsReadOnly="False"
                                          AutoGenerateColumns="False"
                                          SelectionMode="Single"
                                          SelectionUnit="FullRow"
                                          FontSize="13"
                                          RowHeight="30"
                                          GridLinesVisibility="Horizontal"
                                          RowHeaderWidth="0">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Marcar" Binding="{Binding IsMarked}" Width="0.7*" />
                                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" />
                                        <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.8*" />
                                        <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.8*" />
                                        <DataGridTextColumn Header="Data Original" Binding="{Binding PrimaryPhotoDate, StringFormat=dd/MM/yyyy HH:mm}" Width="1.3*" />
                                        <DataGridTextColumn Header="Modificação" Binding="{Binding LastWriteTime, StringFormat=dd/MM/yyyy HH:mm}" Width="1.3*" />
                                        <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.9*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="{StaticResource CardBrush}"
                                    CornerRadius="12"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Border CornerRadius="10"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="10"
                                            MinHeight="460"
                                            Background="#F3F7FB">
                                        <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                        <TextBlock Text="Pré-visualização"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#2E3A46" />
                                        <TextBlock Text="{Binding SelectedItem.Name, TargetNullValue=Selecione um arquivo na lista}" Margin="0,4,0,0" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedItem.FullPath}" TextWrapping="Wrap" Foreground="#55606B" FontSize="11" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Arquivos Indesejados">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="Extensões para limpeza (separadas por vírgula)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="4,0,4,2" />
                                <TextBox Width="380" Text="{Binding UnwantedExtensions, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Button Content="Buscar Arquivos Indesejados"
                                    Command="{Binding ScanUnwantedCommand}"
                                    Margin="14,20,4,4" />
                            <Button Content="Marcar Todos"
                                    Command="{Binding MarkAllUnwantedItemsCommand}"
                                    Margin="4,20,4,4" />
                            <Button Content="Desmarcar Todos"
                                    Command="{Binding UnmarkAllUnwantedItemsCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Margin="4,20,4,4" />
                            <Button Content="Excluir Marcados"
                                    Command="{Binding DeleteMarkedUnwantedCommand}"
                                    Background="#B42318"
                                    Margin="4,20,4,4" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8">
                        <DataGrid ItemsSource="{Binding UnwantedItems}"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.9*" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.9*" />
                                <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.9*" />
                                <DataGridTextColumn Header="Caminho" Binding="{Binding FullPath}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Lista de Exclusão">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8"
                            Margin="0,0,0,10">
                        <Expander Header="Regras, Similaridade e Ações"
                                  IsExpanded="False"
                                  FontWeight="SemiBold"
                                  Foreground="#2E3A46">
                            <Grid Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <WrapPanel Grid.Row="0">
                                    <TextBlock Text="Regras:"
                                               VerticalAlignment="Center"
                                               Margin="4,8,6,0"
                                               FontWeight="SemiBold" />
                                    <CheckBox Content="Mesmo nome"
                                              IsChecked="{Binding UseSameNameRule}" />
                                    <CheckBox Content="Mesmo tamanho"
                                              IsChecked="{Binding UseSameSizeRule}" />
                                    <CheckBox Content="Semelhantes em sequência"
                                              IsChecked="{Binding UseSimilarInSequenceRule}"
                                              ToolTip="Compara fotos próximas no tempo para sugerir imagens parecidas da mesma sequência." />

                                    <StackPanel Margin="8,0,0,0">
                                        <TextBlock Text="Janela (segundos)" FontSize="12" Margin="4,0,4,2" />
                                        <TextBox Width="120"
                                                 Text="{Binding SimilarSecondsWindow, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Tempo máximo entre duas fotos para serem comparadas como sequência (ex: 5, 10, 30)." />
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Distância similaridade" FontSize="12" Margin="4,0,4,2" />
                                        <TextBox Width="150"
                                                 Text="{Binding SimilarDistanceThreshold, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Sensibilidade visual. Menor valor = mais rigoroso (só muito parecidas). Maior valor = mais flexível." />
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Preferência para manter" FontSize="12" Margin="4,0,4,2" />
                                        <ComboBox Width="170"
                                                  ItemsSource="{Binding KeepPreferenceOptions}"
                                                  SelectedItem="{Binding KeepPreference}" />
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Modo de limpeza" FontSize="12" Margin="4,0,4,2" />
                                        <ComboBox Width="130"
                                                  ItemsSource="{Binding CleanupModes}"
                                                  SelectedItem="{Binding CleanupMode}" />
                                    </StackPanel>
                                </WrapPanel>

                                <WrapPanel Grid.Row="1" Margin="0,4,0,0">
                                    <Button Content="Aplicar Modo"
                                            Command="{Binding ApplyCleanupModeCommand}"
                                            Margin="4" />
                                    <Button Content="Gerar Lista de Exclusão"
                                            Command="{Binding GenerateDeletionListCommand}"
                                            Margin="4" />
                                    <Button Content="Marcar Todos"
                                            Command="{Binding MarkAllDeletionCandidatesCommand}"
                                            Margin="4" />
                                    <Button Content="Desmarcar Todos"
                                            Command="{Binding UnmarkAllDeletionCandidatesCommand}"
                                            Background="{StaticResource AccentBrush}"
                                            Margin="4" />
                                    <Button Content="Seleção Automática"
                                            Command="{Binding AutoSelectByGroupCommand}"
                                            Margin="4" />
                                    <Button Content="Modo Revisão Focada"
                                            Command="{Binding StartFocusedReviewCommand}"
                                            Margin="4" />
                                    <Button Content="Modo Revisão em Lista"
                                            Command="{Binding StartListReviewCommand}"
                                            Margin="4" />
                                    <Button Content="Exportar CSV"
                                            Command="{Binding ExportDeletionListCommand}"
                                            Margin="4" />
                                    <Button Content="Exportar TXT"
                                            Command="{Binding ExportDeletionListTxtCommand}"
                                            Margin="4" />
                                    <CheckBox Content="Modo comparação"
                                              IsChecked="{Binding CompareModeEnabled}"
                                              Margin="8,6,4,4"
                                              ToolTip="Exibe lado a lado: foto selecionada e foto mantida do grupo." />
                                    <TextBlock Text="{Binding MarkedDeletionCount, StringFormat=Marcados: {0}}"
                                               Margin="12,10,4,4"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding MarkedDeletionSizeLabel, StringFormat=Espaço estimado: {0}}"
                                               Margin="8,10,4,4"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </WrapPanel>
                            </Grid>
                        </Expander>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="1.65*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8">
                            <DataGrid ItemsSource="{Binding DeletionCandidates}"
                                      SelectedItem="{Binding SelectedDeletionCandidate}"
                                      AutoGenerateColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                <Setter Property="Background" Value="#FFF7E7" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.5*" />
                                    <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.8*" />
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.8*" />
                                    <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.8*" />
                                    <DataGridTextColumn Header="Similaridade" Binding="{Binding SimilarityLabel}" Width="0.9*" />
                                    <DataGridTextColumn Header="Resolução" Binding="{Binding Item.ResolutionLabel}" Width="0.9*" />
                                    <DataGridTextColumn Header="Grupo" Binding="{Binding GroupLabel}" Width="1.6*" />
                                    <DataGridTextColumn Header="Estado" Binding="{Binding DeletionStateLabel}" Width="1.1*" />
                                    <DataGridTextColumn Header="Regra" Binding="{Binding Rule}" Width="1.2*" />
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="2.3*" />
                                    <DataGridTextColumn Header="Manter (arquivo)" Binding="{Binding KeepFilePath}" Width="2.3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompareModeEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Border CornerRadius="10"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="8"
                                            Background="#F8FAFC">
                                        <Image Source="{Binding DeletionPreviewImage}" Stretch="Uniform" />
                                    </Border>
                                </Grid>

                                <Grid>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompareModeEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            CornerRadius="10"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="6"
                                            Background="#F8FAFC">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Selecionada"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2E3A46"
                                                       Margin="2,0,0,6" />
                                            <Image Grid.Row="1"
                                                   Source="{Binding DeletionPreviewImage}"
                                                   Stretch="Uniform" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Column="2"
                                            CornerRadius="10"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Padding="6"
                                            Background="#F8FAFC">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Original mantida"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2E3A46"
                                                       Margin="2,0,0,6" />
                                            <Image Grid.Row="1"
                                                   Source="{Binding KeepDeletionPreviewImage}"
                                                   Stretch="Uniform" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Text="Revisão antes da exclusão"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#2E3A46" />
                                    <TextBlock Text="{Binding SelectedDeletionCandidate.Name, TargetNullValue=Selecione um item da lista}" Margin="0,4,0,0" FontWeight="SemiBold" />
                                    <Button Content="Explicação"
                                            Command="{Binding ShowDeletionExplanationCommand}"
                                            Padding="8,4"
                                            FontSize="11"
                                            Margin="0,6,0,0"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                CornerRadius="10"
                Padding="10"
                Margin="0,12,0,0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Button Content="Excluir Marcados"
                        Command="{Binding DeleteMarkedCandidatesCommand}"
                        Background="#B42318"
                        Foreground="White"
                        Padding="10,6"
                        Margin="8,0,0,0"
                        DockPanel.Dock="Right" />
                <Button Content="Desfazer Selecionado"
                        Command="{Binding UndoSelectedOperationCommand}"
                        Background="#99F6E4"
                        Foreground="#111827"
                        FontWeight="SemiBold"
                        Padding="10,6"
                        Margin="8,0,0,0"
                        DockPanel.Dock="Right" />
                <ComboBox Width="300"
                          Margin="8,0,0,0"
                          ItemsSource="{Binding UndoBatchOptions}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedUndoBatchId}"
                          DisplayMemberPath="DisplayLabel"
                          ToolTip="Selecione um lote para desfazer."
                          DockPanel.Dock="Right" />
                <Button Content="Desfazer Última"
                        Command="{Binding UndoLastOperationCommand}"
                        Background="#C4B5FD"
                        Foreground="#111827"
                        FontWeight="SemiBold"
                        Padding="10,6"
                        Margin="8,0,0,0"
                        DockPanel.Dock="Right" />
                <Button Content="Cancelar"
                        Command="{Binding CancelCurrentOperationCommand}"
                        Background="#B42318"
                        Foreground="White"
                        Padding="10,6"
                        Margin="8,0,0,0"
                        DockPanel.Dock="Right"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Width="280"
                                     Height="12"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding OperationProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{Binding IsProgressIndeterminate}" />
                        <TextBlock Text="{Binding OperationProgressLabel}"
                                   Foreground="#1F6F8B"
                                   FontWeight="SemiBold"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="900"
              Background="#CC0B1A24"
              Visibility="{Binding IsFocusedReviewMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Margin="18"
                    CornerRadius="14"
                    Padding="14"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <Button Content="Sair da Revisão"
                                Command="{Binding ExitFocusedReviewCommand}"
                                Background="{StaticResource AccentBrush}"
                                DockPanel.Dock="Right" />
                        <StackPanel>
                            <TextBlock Text="Modo Revisão Focada"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1F6F8B" />
                            <TextBlock Text="{Binding FocusedReviewProgressLabel, StringFormat=Progresso: {0}}"
                                       FontWeight="SemiBold"
                                       Foreground="#2E3A46"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="1.1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8"
                                Background="#F8FAFC">
                            <Image Source="{Binding DeletionPreviewImage}" Stretch="Uniform" />
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8"
                                Background="#F8FAFC">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="220" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="200" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Original mantida"
                                           FontWeight="SemiBold"
                                           Foreground="#2E3A46" />
                                <Border Grid.Row="1"
                                        Margin="0,6,0,10"
                                        CornerRadius="8"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Background="White">
                                    <Image Source="{Binding KeepDeletionPreviewImage}" Stretch="Uniform" />
                                </Border>

                                <StackPanel Grid.Row="2" Margin="0,0,0,8">
                                    <TextBlock Text="{Binding FocusedGroupSummary}"
                                               FontWeight="SemiBold"
                                               Foreground="#2E3A46" />
                                    <TextBlock Text="Selecione no grupo para comparar, trocar original ou excluir todo o conjunto."
                                               TextWrapping="Wrap"
                                               FontSize="11"
                                               Foreground="#55606B"
                                               Margin="0,2,0,0" />
                                </StackPanel>

                                <DataGrid Grid.Row="3"
                                          ItemsSource="{Binding FocusedGroupItems}"
                                          SelectedItem="{Binding SelectedFocusedGroupItem}"
                                          AutoGenerateColumns="False"
                                          RowHeaderWidth="0"
                                          GridLinesVisibility="Horizontal"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                        <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.6*" />
                                        <DataGridTextColumn Header="Estado" Binding="{Binding DeletionStateLabel}" Width="1*" />
                                        <DataGridTextColumn Header="Similaridade" Binding="{Binding SimilarityLabel}" Width="0.9*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <WrapPanel Grid.Row="4" Margin="0,8,0,0">
                                    <Button Content="Definir como original"
                                            Command="{Binding FocusedReviewSetOriginalCommand}" />
                                    <Button Content="Excluir grupo inteiro"
                                            Command="{Binding FocusedReviewDeleteGroupCommand}"
                                            Background="#B42318" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="2" Margin="0,12,0,0">
                        <Button Content="Anterior"
                                Command="{Binding FocusedReviewPreviousCommand}" />
                        <Button Content="Manter"
                                Command="{Binding FocusedReviewKeepCommand}"
                                Background="#0F766E"
                                Margin="8,0,0,0" />
                        <Button Content="Excluir"
                                Command="{Binding FocusedReviewDeleteCommand}"
                                Background="#B42318"
                                Margin="8,0,0,0" />
                        <Button Content="Modo Lista"
                                Command="{Binding StartListReviewCommand}"
                                Margin="8,0,0,0" />
                        <Button Content="Próxima"
                                Command="{Binding FocusedReviewNextCommand}"
                                Margin="8,0,0,0" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="920"
              Background="#CC0B1A24"
              Visibility="{Binding IsListReviewMode, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Margin="18"
                    CornerRadius="14"
                    Padding="14"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                        <Button Content="Sair da Lista"
                                Command="{Binding ExitListReviewCommand}"
                                Background="{StaticResource AccentBrush}"
                                DockPanel.Dock="Right" />
                        <StackPanel>
                            <TextBlock Text="Modo Revisão em Lista"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#1F6F8B" />
                            <TextBlock Text="{Binding ListReviewSummary}"
                                       FontWeight="SemiBold"
                                       Foreground="#2E3A46"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </DockPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.45*" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="1.15*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8"
                                Background="#F8FAFC">
                            <DataGrid ItemsSource="{Binding ListReviewItems}"
                                      SelectedItem="{Binding SelectedListReviewCandidate}"
                                      AutoGenerateColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0"
                                      CanUserAddRows="False">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                    <DataGridTextColumn Header="Grupo" Binding="{Binding GroupLabel}" Width="1.7*" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.5*" />
                                    <DataGridTextColumn Header="Estado" Binding="{Binding DeletionStateLabel}" Width="1*" />
                                    <DataGridTextColumn Header="Similaridade" Binding="{Binding SimilarityLabel}" Width="0.9*" />
                                    <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.9*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                CornerRadius="10"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8"
                                Background="#F8FAFC">
                            <StackPanel>
                                <CheckBox Content="Modo comparação"
                                          IsChecked="{Binding CompareModeEnabled}" />

                                <Grid Margin="0,8,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompareModeEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Border CornerRadius="8"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Background="White"
                                            Height="320">
                                        <Image Source="{Binding DeletionPreviewImage}" Stretch="Uniform" />
                                    </Border>
                                </Grid>

                                <Grid Margin="0,8,0,0">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CompareModeEnabled}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Background="White"
                                            Height="190">
                                        <Image Source="{Binding DeletionPreviewImage}" Stretch="Uniform" />
                                    </Border>
                                    <Border Grid.Column="2"
                                            CornerRadius="8"
                                            BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1"
                                            Background="White"
                                            Height="190">
                                        <Image Source="{Binding KeepDeletionPreviewImage}" Stretch="Uniform" />
                                    </Border>
                                </Grid>

                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Definir como original"
                                            Command="{Binding ListReviewSetOriginalCommand}" />
                                    <Button Content="Excluir grupo inteiro"
                                            Command="{Binding ListReviewDeleteGroupCommand}"
                                            Background="#B42318" />
                                </WrapPanel>
                                <TextBlock Text="Excluir grupo inteiro remove todas as fotos do conjunto selecionado."
                                           Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#55606B"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <DockPanel Grid.Row="2" Margin="0,10,0,0">
                        <Button Content="Abrir revisão focada"
                                Command="{Binding StartFocusedReviewCommand}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="4"
              Panel.ZIndex="1000"
              Background="#660B1A24"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="520"
                    MaxWidth="680"
                    CornerRadius="14"
                    Padding="16"
                    Background="White"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Processando..."
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#1F6F8B" />
                    <TextBlock Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"
                               Margin="0,8,0,0"
                               Foreground="#2E3A46" />
                    <TextBlock Text="{Binding OperationProgressLabel}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"
                               Foreground="#55606B" />
                    <ProgressBar Height="14"
                                 Margin="0,12,0,0"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding OperationProgressPercent, Mode=OneWay}"
                                 IsIndeterminate="{Binding IsProgressIndeterminate}" />
                    <Button Content="Cancelar Operação"
                            Command="{Binding CancelCurrentOperationCommand}"
                            Background="#B42318"
                            Foreground="White"
                            HorizontalAlignment="Right"
                            Margin="0,14,0,0"
                            Padding="14,8" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

