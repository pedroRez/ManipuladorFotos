<Window x:Class="ManipuladorFotos.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Manipulador de Fotos"
        Height="860"
        Width="1400"
        MinHeight="720"
        MinWidth="1100"
        WindowState="Maximized"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F5F7FA"
        WindowStartupLocation="CenterScreen"
        Icon="icon.ico">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1F6F8B" />
        <SolidColorBrush x:Key="AccentBrush" Color="#E07A5F" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#D8DFE6" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Style TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="White" />
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Margin" Value="4" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Margin" Value="4" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="6,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,12"
                Background="#1F6F8B">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="Manipulador de Fotos"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White" />
                    <TextBlock Text="Organize, filtre e prepare limpeza de mídia com segurança"
                               FontSize="14"
                               Foreground="#E8F1F5"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Border Width="10" />
                <TextBlock Text="Fase 2: Lista de exclusão com revisão visual"
                           VerticalAlignment="Bottom"
                           Foreground="#E8F1F5"
                           FontWeight="SemiBold"
                           Margin="12,0,0,2" />
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Background="{StaticResource CardBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="10"
                Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding CurrentFolder, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" />
                <Button Grid.Column="1"
                        Content="Escolher Pasta"
                        Command="{Binding BrowseFolderCommand}" />
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Incluir subpastas"
                              IsChecked="{Binding IncludeSubfolders}" />
                    <CheckBox Content="Dry Run"
                              IsChecked="{Binding IsDryRun}"
                              ToolTip="Quando ativo, apenas simula operações sem alterar arquivos." />
                    <Button Content="Escanear"
                            Command="{Binding ScanFilesCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0">
            <TabItem Header="Organizar Fotos">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="Nome contém" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <TextBox Width="170" Text="{Binding NameFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Extensão" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <TextBox Width="100" Text="{Binding ExtensionFilter, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Tipo" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <ComboBox Width="110"
                                          ItemsSource="{Binding TypeOptions}"
                                          SelectedItem="{Binding TypeFilter}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Data original de" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <DatePicker SelectedDate="{Binding CreatedFrom}" Width="140" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Data original até" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <DatePicker SelectedDate="{Binding CreatedTo}" Width="140" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Data original (extra) de" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <DatePicker SelectedDate="{Binding ModifiedFrom}" Width="140" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Data original (extra) até" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <DatePicker SelectedDate="{Binding ModifiedTo}" Width="140" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Min (KB)" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <TextBox Width="90" Text="{Binding MinSizeKb, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Max (KB)" FontSize="12" FontWeight="SemiBold" Margin="4,0,4,2" />
                                <TextBox Width="90" Text="{Binding MaxSizeKb, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="10,16,0,0">
                                <Button Content="Aplicar Filtros"
                                        Command="{Binding ApplyFiltersCommand}" />
                                <Button Content="Limpar"
                                        Background="{StaticResource AccentBrush}"
                                        Command="{Binding ClearFiltersCommand}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,16,0,0">
                                <TextBox Width="180"
                                         Text="{Binding NewMoveFolderPath, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Nome da nova pasta (ou caminho completo) para mover as fotos marcadas." />
                                <Button Content="Mover Selecionadas"
                                        Command="{Binding MoveMarkedPhotosCommand}" />
                                <Button Content="Separar Fotos/Vídeos"
                                        Command="{Binding SeparateMediaCommand}" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="16,16,0,0">
                                <ComboBox Width="130"
                                          ItemsSource="{Binding DateOrganizationModes}"
                                          SelectedItem="{Binding DateOrganizationMode}" />
                                <CheckBox Content="Consolidar subpastas"
                                          IsChecked="{Binding FlattenSubfoldersByDate}"
                                          ToolTip="Quando ativo, move todas as fotos para uma base única e organiza por data." />
                                <TextBox Width="170"
                                         Text="{Binding DateOrganizationBaseFolder, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Pasta base usada quando consolidar subpastas estiver ativo." />
                                <Button Content="Organizar por Data"
                                        Command="{Binding OrganizePhotosByDateCommand}" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8">
                            <DataGrid ItemsSource="{Binding DisplayedItems}"
                                      SelectedItem="{Binding SelectedItem}"
                                      IsReadOnly="False"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Single"
                                      SelectionUnit="FullRow"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Marcar" Binding="{Binding IsMarked}" Width="0.7*" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.8*" />
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.8*" />
                                    <DataGridTextColumn Header="Data Original" Binding="{Binding PrimaryPhotoDate, StringFormat=dd/MM/yyyy HH:mm}" Width="1.3*" />
                                    <DataGridTextColumn Header="Modificação" Binding="{Binding LastWriteTime, StringFormat=dd/MM/yyyy HH:mm}" Width="1.3*" />
                                    <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.9*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border CornerRadius="10"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="8"
                                        Background="#F8FAFC">
                                    <Image Source="{Binding PreviewImage}" Stretch="Uniform" />
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Text="Pré-visualização lateral"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#2E3A46" />
                                    <TextBlock Text="{Binding SelectedItem.Name, TargetNullValue=Selecione um arquivo na lista}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SelectedItem.FullPath}" TextWrapping="Wrap" Foreground="#55606B" />
                                    <TextBlock Text="Para vídeos e outros tipos, o preview de imagem pode não aparecer."
                                               Margin="0,8,0,0"
                                               Foreground="#6B7280"
                                               FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Arquivos Indesejados">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <WrapPanel>
                            <StackPanel>
                                <TextBlock Text="Extensões para limpeza (separadas por vírgula)"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Margin="4,0,4,2" />
                                <TextBox Width="380" Text="{Binding UnwantedExtensions, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <Button Content="Buscar Arquivos Indesejados"
                                    Command="{Binding ScanUnwantedCommand}"
                                    Margin="14,20,4,4" />
                            <Button Content="Excluir Marcados"
                                    Command="{Binding DeleteMarkedUnwantedCommand}"
                                    Background="#B42318"
                                    Margin="4,20,4,4" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="8">
                        <DataGrid ItemsSource="{Binding UnwantedItems}"
                                  AutoGenerateColumns="False"
                                  GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.9*" />
                                <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.9*" />
                                <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.9*" />
                                <DataGridTextColumn Header="Caminho" Binding="{Binding FullPath}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Lista de Exclusão">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="{StaticResource CardBrush}"
                            CornerRadius="12"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,10">
                        <WrapPanel>
                            <TextBlock Text="Regras:"
                                       VerticalAlignment="Center"
                                       Margin="4,8,6,0"
                                       FontWeight="SemiBold" />
                            <CheckBox Content="Mesmo nome"
                                      IsChecked="{Binding UseSameNameRule}" />
                            <CheckBox Content="Mesmo tamanho"
                                      IsChecked="{Binding UseSameSizeRule}" />
                            <CheckBox Content="Semelhantes em sequência"
                                      IsChecked="{Binding UseSimilarInSequenceRule}"
                                      ToolTip="Compara fotos próximas no tempo para sugerir imagens parecidas da mesma sequência." />

                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Text="Janela (segundos)" FontSize="12" Margin="4,0,4,2" />
                                <TextBox Width="120"
                                         Text="{Binding SimilarSecondsWindow, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Tempo máximo entre duas fotos para serem comparadas como sequência (ex: 5, 10, 30)." />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Distância similaridade" FontSize="12" Margin="4,0,4,2" />
                                <TextBox Width="150"
                                         Text="{Binding SimilarDistanceThreshold, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="Sensibilidade visual. Menor valor = mais rigoroso (só muito parecidas). Maior valor = mais flexível." />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Preferência para manter" FontSize="12" Margin="4,0,4,2" />
                                <ComboBox Width="170"
                                          ItemsSource="{Binding KeepPreferenceOptions}"
                                          SelectedItem="{Binding KeepPreference}" />
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Modo de limpeza" FontSize="12" Margin="4,0,4,2" />
                                <ComboBox Width="130"
                                          ItemsSource="{Binding CleanupModes}"
                                          SelectedItem="{Binding CleanupMode}" />
                            </StackPanel>

                            <Button Content="Gerar Lista de Exclusão"
                                    Command="{Binding GenerateDeletionListCommand}"
                                    Margin="14,20,4,4" />
                            <Button Content="Aplicar Modo"
                                    Command="{Binding ApplyCleanupModeCommand}"
                                    Margin="4,20,4,4" />
                            <Button Content="Marcar Todos"
                                    Command="{Binding MarkAllDeletionCandidatesCommand}"
                                    Margin="4,20,4,4" />
                            <Button Content="Desmarcar Todos"
                                    Command="{Binding UnmarkAllDeletionCandidatesCommand}"
                                    Background="{StaticResource AccentBrush}"
                                    Margin="4,20,4,4" />
                            <Button Content="Seleção Automática"
                                    Command="{Binding AutoSelectByGroupCommand}"
                                    Margin="4,20,4,4" />
                            <Button Content="Excluir Marcados (Lixeira)"
                                    Command="{Binding DeleteMarkedCandidatesCommand}"
                                    Background="#B42318"
                                    Margin="4,20,4,4" />
                            <Button Content="Exportar CSV"
                                    Command="{Binding ExportDeletionListCommand}"
                                    Margin="4,20,4,4" />
                            <TextBlock Text="{Binding MarkedDeletionCount, StringFormat=Marcados: {0}}"
                                       Margin="14,24,4,4"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MarkedDeletionSizeLabel, StringFormat=Espaço estimado: {0}}"
                                       Margin="8,24,4,4"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold" />
                        </WrapPanel>
                    </Border>

                    <Border Grid.Row="1"
                            Background="#EEF6FB"
                            CornerRadius="10"
                            BorderBrush="#C9DEEE"
                            BorderThickness="1"
                            Padding="8,6"
                            Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Como funciona a similaridade"
                                       FontWeight="SemiBold"
                                       Foreground="#1F4F72"
                                       Margin="0,0,12,0" />
                            <TextBlock Text="Janela: limita sequência | Distância: menor = rígido, maior = permissivo | Sugestão inicial: 10s / 8"
                                       Foreground="#2E3A46" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="8">
                            <DataGrid ItemsSource="{Binding DeletionCandidates}"
                                      SelectedItem="{Binding SelectedDeletionCandidate}"
                                      AutoGenerateColumns="False"
                                      GridLinesVisibility="Horizontal"
                                      RowHeaderWidth="0">
                                <DataGrid.RowStyle>
                                    <Style TargetType="DataGridRow">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                <Setter Property="Background" Value="#FFF7E7" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.RowStyle>
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding IsMarked}" Width="0.7*" />
                                    <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="1.5*" />
                                    <DataGridTextColumn Header="Extensão" Binding="{Binding Extension}" Width="0.8*" />
                                    <DataGridTextColumn Header="Tipo" Binding="{Binding Kind}" Width="0.8*" />
                                    <DataGridTextColumn Header="Tamanho" Binding="{Binding SizeLabel}" Width="0.8*" />
                                    <DataGridTextColumn Header="Resolução" Binding="{Binding Item.ResolutionLabel}" Width="0.9*" />
                                    <DataGridTextColumn Header="Grupo" Binding="{Binding GroupLabel}" Width="1.6*" />
                                    <DataGridTextColumn Header="Estado" Binding="{Binding DeletionStateLabel}" Width="1.1*" />
                                    <DataGridTextColumn Header="Regra" Binding="{Binding Rule}" Width="1.2*" />
                                    <DataGridTextColumn Header="Motivo" Binding="{Binding Reason}" Width="2.3*" />
                                    <DataGridTextColumn Header="Manter (arquivo)" Binding="{Binding KeepFilePath}" Width="2.3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <Border Grid.Column="2"
                                Background="{StaticResource CardBrush}"
                                CornerRadius="12"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border CornerRadius="10"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1"
                                        Padding="8"
                                        Background="#F8FAFC">
                                    <Image Source="{Binding DeletionPreviewImage}" Stretch="Uniform" />
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                    <TextBlock Text="Revisão antes da exclusão"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="#2E3A46" />
                                    <TextBlock Text="{Binding SelectedDeletionCandidate.Name, TargetNullValue=Selecione um item da lista}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding SelectedDeletionCandidate.Reason}" TextWrapping="Wrap" Foreground="#55606B" />
                                    <TextBlock Text="{Binding SelectedDeletionCandidate.FullPath}" Margin="0,6,0,0" TextWrapping="Wrap" Foreground="#55606B" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3"
                CornerRadius="10"
                Padding="10"
                Margin="0,12,0,0"
                Background="#FFFFFF"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1">
            <DockPanel LastChildFill="True">
                <Button Content="Cancelar"
                        Command="{Binding CancelCurrentOperationCommand}"
                        Background="#B42318"
                        Foreground="White"
                        Padding="10,6"
                        Margin="8,0,0,0"
                        DockPanel.Dock="Right"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal"
                                Margin="0,6,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar Width="280"
                                     Height="12"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding OperationProgressPercent, Mode=OneWay}"
                                     IsIndeterminate="{Binding IsProgressIndeterminate}" />
                        <TextBlock Text="{Binding OperationProgressLabel}"
                                   Foreground="#1F6F8B"
                                   FontWeight="SemiBold"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
